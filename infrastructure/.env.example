# =============================================================
# Enterprise Supermarket POS & ERP System — Environment Config
# Copy this file:  cp .env.example .env
# Then edit .env with your own secure values!
# =============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SuperSecure_Db_Pass_2026!
DB_NAME=PosErpDb

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_SuperSecure_Redis_Pass_2026!

# ── JWT Authentication ───────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_YourSuperLongAndSecureJwtSecretKeyHereThatIsAtLeast32Bytes
JWT_ISSUER=PosErpSystem
JWT_AUDIENCE=PosErpFrontend
